# CLI wiring
# =============================================================================

def main():
    parser = argparse.ArgumentParser(
        prog="agentctl",
        description="Lightweight CLI for managing AI agent tasks and state"
    )
    parser.add_argument("--db", type=Path, help="Database path (default: ~/.agentctl/tasks.db)")
    parser.add_argument("--version", action="version", version=f"%(prog)s {__version__}")

    subparsers = parser.add_subparsers(dest="command", help="Commands")

    # add
    add_parser = subparsers.add_parser("add", help="Add a new task")
    add_parser.add_argument("title", help="Task title")
    add_parser.add_argument("-d", "--description", help="Task description")
    add_parser.add_argument("-p", "--priority", choices=["low", "medium", "high"],
                            default="medium", help="Task priority")
    add_parser.add_argument("--tags", help="Comma-separated tags (e.g. deploy,urgent)")
    add_parser.add_argument("--due", metavar="DATE",
                            help="Due date: +1h / +2d / +30m (relative) or YYYY-MM-DD / YYYY-MM-DDTHH:MM")
    add_parser.add_argument("-m", "--metadata", help="JSON metadata string")
    add_parser.set_defaults(func=cmd_add)

    # list
    list_parser = subparsers.add_parser("list", help="List tasks")
    list_parser.add_argument("-s", "--status",
                             choices=["pending", "in_progress", "completed", "blocked"],
                             help="Filter by status")
    list_parser.add_argument("--tag", help="Filter by tag")
    list_parser.add_argument("--overdue", action="store_true",
                             help="Show only overdue tasks (past due date, not completed)")
    list_parser.add_argument("-n", "--limit", type=int, default=50, help="Limit results")
    list_parser.set_defaults(func=cmd_list)

    # show
    show_parser = subparsers.add_parser("show", help="Show task details (including notes)")
    show_parser.add_argument("task_id", type=int, help="Task ID")
    show_parser.set_defaults(func=cmd_show)

    # update
    update_parser = subparsers.add_parser("update", help="Update a task")
    update_parser.add_argument("task_id", type=int, help="Task ID")
    update_parser.add_argument("-t", "--title", help="New title")
    update_parser.add_argument("-d", "--description", help="New description")
    update_parser.add_argument("-s", "--status",
                               choices=["pending", "in_progress", "completed", "blocked"],
                               help="New status")
    update_parser.add_argument("-p", "--priority", choices=["low", "medium", "high"],
                               help="New priority")
    update_parser.add_argument("--tags",
                               help="Comma-separated tags. Pass empty string to clear.")
    update_parser.add_argument("--due", metavar="DATE",
                               help="New due date: +1h / +2d / YYYY-MM-DD / YYYY-MM-DDTHH:MM")
    update_parser.add_argument("--clear-due", action="store_true",
                               help="Remove the due date")
    update_parser.add_argument("-m", "--metadata", help="JSON metadata string")
    update_parser.set_defaults(func=cmd_update)

    # note
    note_parser = subparsers.add_parser("note", help="Append a timestamped note to a task")
    note_parser.add_argument("task_id", type=int, help="Task ID")
    note_parser.add_argument("text", help="Note text")
    note_parser.set_defaults(func=cmd_note)

    # delete
    delete_parser = subparsers.add_parser("delete", help="Delete a task")
    delete_parser.add_argument("task_id", type=int, help="Task ID")
    delete_parser.set_defaults(func=cmd_delete)

    # status
    status_parser = subparsers.add_parser("status", help="Show overall status")
    status_parser.set_defaults(func=cmd_status)

    # tags
    tags_parser = subparsers.add_parser("tags", help="List all tags with task counts")
    tags_parser.set_defaults(func=cmd_tags)

    # state
    state_parser = subparsers.add_parser("state", help="Manage state values")
    state_subparsers = state_parser.add_subparsers(dest="state_command", help="State commands")

    state_set_parser = state_subparsers.add_parser("set", help="Set a state value")
    state_set_parser.add_argument("key", help="State key")
    state_set_parser.add_argument("value", help="State value")
    state_set_parser.set_defaults(func=cmd_state_set)

    state_get_parser = state_subparsers.add_parser("get", help="Get a state value")
    state_get_parser.add_argument("key", help="State key")
    state_get_parser.set_defaults(func=cmd_state_get)

    # log
    log_parser = subparsers.add_parser("log", help="Log a structured event")
    log_parser.add_argument("message", help="Event message")
    log_parser.add_argument("--tag", help="Optional tag")
    log_parser.add_argument("--data", help="Optional JSON data payload")
    log_parser.set_defaults(func=cmd_log)

    # logs
    logs_parser = subparsers.add_parser("logs", help="List recent events")
    logs_parser.add_argument("--tag", help="Filter by tag")
    logs_parser.add_argument("--since", metavar="DURATION",
                             help="Only show events from the last DURATION (e.g. 1h, 24h, 7d)")
    logs_parser.add_argument("-n", "--limit", type=int, default=50, help="Limit results")
    logs_parser.add_argument("--data", action="store_true",
                             help="Also print the data payload for each event")
    logs_parser.set_defaults(func=cmd_logs)

    # report
    report_parser = subparsers.add_parser("report", help="Generate a summary report")
    report_parser.add_argument("--since", metavar="DURATION", default="24h",
                               help="Report window (default: 24h). E.g. 1h, 7d")
    report_parser.set_defaults(func=cmd_report)

    # checkpoint
    cp_parser = subparsers.add_parser("checkpoint", help="Export full state to a JSON file")
    cp_parser.add_argument("-o", "--output", help="Output file path (default: auto-named)")
    cp_parser.set_defaults(func=cmd_checkpoint)

    # restore
    restore_parser = subparsers.add_parser("restore", help="Restore state from a checkpoint file")
    restore_parser.add_argument("file", help="Checkpoint JSON file to restore from")
    restore_parser.add_argument("--merge", action="store_true",
                                help="Merge into existing data instead of replacing")
    restore_parser.set_defaults(func=cmd_restore)

    # purge
    purge_parser = subparsers.add_parser("purge", help="Delete all data (or specific tables)")
    purge_parser.add_argument("target", nargs="?", default="all",
                              choices=["tasks", "events", "state", "notes", "all"],
                              help="What to purge (default: all)")
    purge_parser.add_argument("-y", "--yes", action="store_true",
                              help="Skip confirmation prompt")
    purge_parser.set_defaults(func=cmd_purge)

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    store = TaskStore(args.db)
    args.func(store, args)


if __name__ == "__main__":
    main()
