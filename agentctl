from pathlib import Path
from typing import Optional

__version__ = "0.5.0"

DEFAULT_DB_PATH = Path.home() / ".agentctl" / "tasks.db"


def parse_duration(duration: str) -> datetime:
    """Parse a duration string (e.g. 1h, 24h, 7d) into a cutoff datetime."""
    duration = duration.strip().lower()
    if duration.endswith("h"):
        hours = int(duration[:-1])
        return datetime.now() - timedelta(hours=hours)
    elif duration.endswith("d"):
        days = int(duration[:-1])
        return datetime.now() - timedelta(days=days)
    elif duration.endswith("m"):
        minutes = int(duration[:-1])
        return datetime.now() - timedelta(minutes=minutes)
    else:
        raise ValueError(f"Unrecognised duration format: {duration!r}. Use e.g. 30m, 1h, 24h, 7d")


def parse_due_date(due_str: str) -> str:
    """
    Parse a due date string into an ISO-8601 datetime string.

    Accepted formats:
      - Relative: +1h, +2d, +30m  (from now)
      - Date only: 2025-06-01       (treated as end of that day 23:59:59)
      - Date+time: 2025-06-01T14:00
    """
    due_str = due_str.strip()
    if due_str.startswith("+"):
        # Relative offset
        offset = due_str[1:].lower()
        if offset.endswith("h"):
            dt = datetime.now() + timedelta(hours=int(offset[:-1]))
        elif offset.endswith("d"):
            dt = datetime.now() + timedelta(days=int(offset[:-1]))
        elif offset.endswith("m"):
            dt = datetime.now() + timedelta(minutes=int(offset[:-1]))
        else:
            raise ValueError(f"Unrecognised relative due format: {due_str!r}. Use e.g. +1h, +2d, +30m")
        return dt.isoformat(timespec="seconds")
    # Try explicit date/datetime
    for fmt in ("%Y-%m-%dT%H:%M:%S", "%Y-%m-%dT%H:%M", "%Y-%m-%d"):
        try:
            dt = datetime.strptime(due_str, fmt)
            if fmt == "%Y-%m-%d":
                dt = dt.replace(hour=23, minute=59, second=59)
            return dt.isoformat(timespec="seconds")
        except ValueError:
            continue
    raise ValueError(
        f"Unrecognised due date format: {due_str!r}. "
        "Use +1h / +2d / +30m for relative, or YYYY-MM-DD / YYYY-MM-DDTHH:MM for absolute."
    )


class TaskStore:
    """SQLite-backed task and event storage."""

    def __init__(self, db_path: Optional[Path] = None):
        self.db_path = db_path or DEFAULT_DB_PATH
        self.db_path.parent.mkdir(parents=True, exist_ok=True)
        self._init_db()

    def _init_db(self):
        """Initialize the database schema."""
        with sqlite3.connect(self.db_path) as conn:
            conn.execute("""
                CREATE TABLE IF NOT EXISTS tasks (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    title TEXT NOT NULL,
                    description TEXT,
                    status TEXT DEFAULT 'pending',
                    priority TEXT DEFAULT 'medium',
                    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                    completed_at TIMESTAMP,
                    metadata TEXT
                )
            """)
            conn.execute("""
                CREATE TABLE IF NOT EXISTS state (
                    key TEXT PRIMARY KEY,
                    value TEXT,
                    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                )
            """)
            conn.execute("""
                CREATE TABLE IF NOT EXISTS events (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                    message TEXT NOT NULL,
                    tag TEXT,
                    data TEXT
                )
            """)
            conn.execute("""
                CREATE TABLE IF NOT EXISTS task_notes (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    task_id INTEGER NOT NULL REFERENCES tasks(id) ON DELETE CASCADE,
                    timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                    note TEXT NOT NULL
                )
            """)
            # Migrations: add columns if missing
            cursor = conn.execute("PRAGMA table_info(tasks)")
            columns = {row[1] for row in cursor.fetchall()}
            if "tags" not in columns:
                conn.execute("ALTER TABLE tasks ADD COLUMN tags TEXT")
            if "due_at" not in columns:
                conn.execute("ALTER TABLE tasks ADD COLUMN due_at TIMESTAMP")
            conn.commit()

    # -------------------------------------------------------------------------
    # Task methods
    # -------------------------------------------------------------------------

    def add_task(self, title: str, description: str = "", priority: str = "medium",
                 metadata: Optional[dict] = None, tags: Optional[str] = None,
                 due_at: Optional[str] = None) -> int:
        """Add a new task. Returns task ID."""
        with sqlite3.connect(self.db_path) as conn:
            cursor = conn.execute(
                """INSERT INTO tasks (title, description, priority, metadata, tags, due_at)
                   VALUES (?, ?, ?, ?, ?, ?)""",
                (title, description, priority,
                 json.dumps(metadata) if metadata else None, tags, due_at)
            )
            conn.commit()
            return cursor.lastrowid

    def list_tasks(self, status: Optional[str] = None, tag: Optional[str] = None,
                   overdue: bool = False, limit: int = 50) -> list:
        """List tasks, optionally filtered by status, tag, and/or overdue."""
        with sqlite3.connect(self.db_path) as conn:
            conn.row_factory = sqlite3.Row
            clauses = []
            params: list = []
            if status:
                clauses.append("status = ?")
                params.append(status)
            if tag:
                clauses.append(
                    "(tags = ? OR tags LIKE ? OR tags LIKE ? OR tags LIKE ?)"
                )
                params.extend([tag, f"{tag},%", f"%,{tag},%", f"%,{tag}"])
            if overdue:
                clauses.append("due_at IS NOT NULL AND due_at < ? AND status NOT IN ('completed')")
                params.append(datetime.now().isoformat())
            where = ("WHERE " + " AND ".join(clauses)) if clauses else ""
            params.append(limit)
            rows = conn.execute(
                f"SELECT * FROM tasks {where} ORDER BY created_at DESC LIMIT ?",
                params
            ).fetchall()
            return [dict(row) for row in rows]

    def get_task(self, task_id: int) -> Optional[dict]:
        """Get a single task by ID."""
        with sqlite3.connect(self.db_path) as conn:
            conn.row_factory = sqlite3.Row
            row = conn.execute(
                "SELECT * FROM tasks WHERE id = ?", (task_id,)
            ).fetchone()
            return dict(row) if row else None

    def update_task(self, task_id: int, **kwargs) -> bool:
        """Update task fields."""
        allowed = {"title", "description", "status", "priority", "metadata", "tags", "due_at"}
        updates = {k: v for k, v in kwargs.items() if k in allowed}

        if not updates:
            return False

        if "status" in updates and updates["status"] == "completed":
            updates["completed_at"] = datetime.now().isoformat()

        updates["updated_at"] = datetime.now().isoformat()

        with sqlite3.connect(self.db_path) as conn:
            set_clause = ", ".join(f"{k} = ?" for k in updates.keys())
            values = list(updates.values()) + [task_id]
            cursor = conn.execute(
                f"UPDATE tasks SET {set_clause} WHERE id = ?",
                values
            )
            conn.commit()
            return cursor.rowcount > 0

    def delete_task(self, task_id: int) -> bool:
        """Delete a task (and its notes, via CASCADE)."""
        with sqlite3.connect(self.db_path) as conn:
            conn.execute("PRAGMA foreign_keys = ON")
            cursor = conn.execute("DELETE FROM tasks WHERE id = ?", (task_id,))
            conn.commit()
            return cursor.rowcount > 0

    # -------------------------------------------------------------------------
    # Notes methods
    # -------------------------------------------------------------------------

    def add_note(self, task_id: int, note: str) -> int:
        """Append a timestamped note to a task. Returns note ID."""
        with sqlite3.connect(self.db_path) as conn:
            cursor = conn.execute(
                "INSERT INTO task_notes (task_id, timestamp, note) VALUES (?, ?, ?)",
                (task_id, datetime.now().isoformat(timespec="seconds"), note)
            )
            conn.commit()
            return cursor.lastrowid

    def get_notes(self, task_id: int) -> list:
        """Return all notes for a task, oldest first."""
        with sqlite3.connect(self.db_path) as conn:
            conn.row_factory = sqlite3.Row
            rows = conn.execute(
                "SELECT * FROM task_notes WHERE task_id = ? ORDER BY timestamp ASC",
                (task_id,)
            ).fetchall()
            return [dict(r) for r in rows]

    # -------------------------------------------------------------------------
    # State methods
    # -------------------------------------------------------------------------

    def set_state(self, key: str, value: str):
        """Set a state value."""
        with sqlite3.connect(self.db_path) as conn:
            conn.execute(
                """INSERT INTO state (key, value, updated_at)
                   VALUES (?, ?, ?)
                   ON CONFLICT(key) DO UPDATE SET
                   value = excluded.value,
                   updated_at = excluded.updated_at""",
                (key, value, datetime.now().isoformat())
            )
            conn.commit()

    def get_state(self, key: str) -> Optional[str]:
        """Get a state value."""
        with sqlite3.connect(self.db_path) as conn:
            row = conn.execute(
                "SELECT value FROM state WHERE key = ?", (key,)
            ).fetchone()
            return row[0] if row else None

    # -------------------------------------------------------------------------
    # Export / import / purge
    # -------------------------------------------------------------------------

    def export_all(self) -> dict:
        """Export all tasks, state, events, and notes as a portable dict."""
        with sqlite3.connect(self.db_path) as conn:
            conn.row_factory = sqlite3.Row
            tasks = [dict(r) for r in conn.execute("SELECT * FROM tasks ORDER BY id").fetchall()]
            state = [dict(r) for r in conn.execute("SELECT * FROM state ORDER BY key").fetchall()]
            events = [dict(r) for r in conn.execute("SELECT * FROM events ORDER BY id").fetchall()]
            notes = [dict(r) for r in conn.execute("SELECT * FROM task_notes ORDER BY id").fetchall()]
        return {
            "version": __version__,
            "exported_at": datetime.now().isoformat(),
            "db_path": str(self.db_path),
            "tasks": tasks,
            "state": state,
            "events": events,
            "notes": notes,
        }

    def import_all(self, data: dict, merge: bool = False):
        """Import tasks, state, events, and notes from a checkpoint dict."""
        with sqlite3.connect(self.db_path) as conn:
            if not merge:
                conn.execute("DELETE FROM task_notes")
                conn.execute("DELETE FROM tasks")
                conn.execute("DELETE FROM state")
                conn.execute("DELETE FROM events")

            for t in data.get("tasks", []):
                cols = ["title", "description", "status", "priority",
                        "created_at", "updated_at", "completed_at", "metadata",
                        "tags", "due_at"]
                vals = [t.get(c) for c in cols]
                conn.execute(
                    f"INSERT INTO tasks ({', '.join(cols)}) VALUES ({', '.join('?' * len(cols))})",
                    vals,
                )

            for s in data.get("state", []):
                conn.execute(
                    "INSERT OR REPLACE INTO state (key, value, updated_at) VALUES (?, ?, ?)",
                    (s["key"], s["value"], s.get("updated_at", datetime.now().isoformat())),
                )

            for e in data.get("events", []):
                conn.execute(
                    "INSERT INTO events (timestamp, message, tag, data) VALUES (?, ?, ?, ?)",
                    (e.get("timestamp"), e["message"], e.get("tag"), e.get("data")),
                )

            for n in data.get("notes", []):
                conn.execute(
                    "INSERT INTO task_notes (task_id, timestamp, note) VALUES (?, ?, ?)",
                    (n["task_id"], n.get("timestamp"), n["note"]),
                )

            conn.commit()

    def purge(self, target: str = "all"):
        """Delete data. target: 'tasks', 'events', 'state', 'notes', or 'all'."""
        tables = {
            "tasks": ["task_notes", "tasks"],
            "events": ["events"],
            "state": ["state"],
            "notes": ["task_notes"],
            "all": ["task_notes", "tasks", "state", "events"],
        }
        if target not in tables:
            raise ValueError(f"Unknown purge target: {target!r}. Use tasks/events/state/notes/all")
        with sqlite3.connect(self.db_path) as conn:
            for tbl in tables[target]:
                conn.execute(f"DELETE FROM {tbl}")
            conn.commit()

    # -------------------------------------------------------------------------
    # Stats / reporting helpers
    # -------------------------------------------------------------------------

    def get_stats(self) -> dict:
        """Get task statistics."""
        with sqlite3.connect(self.db_path) as conn:
            total = conn.execute("SELECT COUNT(*) FROM tasks").fetchone()[0]
            pending = conn.execute(
                "SELECT COUNT(*) FROM tasks WHERE status = 'pending'"
            ).fetchone()[0]
            in_progress = conn.execute(
                "SELECT COUNT(*) FROM tasks WHERE status = 'in_progress'"
            ).fetchone()[0]
            completed = conn.execute(
                "SELECT COUNT(*) FROM tasks WHERE status = 'completed'"
            ).fetchone()[0]
            overdue = conn.execute(
                "SELECT COUNT(*) FROM tasks WHERE due_at IS NOT NULL AND due_at < ? AND status NOT IN ('completed')",
                (datetime.now().isoformat(),)
            ).fetchone()[0]
            return {
                "total": total,
                "pending": pending,
                "in_progress": in_progress,
                "completed": completed,
                "overdue": overdue,
            }

    def get_tags(self) -> list:
        """Return all task tags with counts, sorted by count descending then name."""
        with sqlite3.connect(self.db_path) as conn:
            rows = conn.execute(
                "SELECT tags FROM tasks WHERE tags IS NOT NULL AND tags != ''"
            ).fetchall()
            tag_counts: dict = {}
            for row in rows:
                for tag in [t.strip() for t in row[0].split(",") if t.strip()]:
                    tag_counts[tag] = tag_counts.get(tag, 0) + 1
            return sorted(tag_counts.items(), key=lambda x: (-x[1], x[0]))

    def add_event(self, message: str, tag: Optional[str] = None,
                  data: Optional[dict] = None) -> int:
        """Log a new event. Returns event ID."""
        with sqlite3.connect(self.db_path) as conn:
            cursor = conn.execute(
                """INSERT INTO events (timestamp, message, tag, data)
                   VALUES (?, ?, ?, ?)""",
                (datetime.now().isoformat(), message, tag,
                 json.dumps(data) if data else None)
            )
            conn.commit()
            return cursor.lastrowid

    def list_events(self, tag: Optional[str] = None,
                    since: Optional[datetime] = None,
                    limit: int = 50) -> list:
        """List events, optionally filtered by tag and/or cutoff time."""
        with sqlite3.connect(self.db_path) as conn:
            conn.row_factory = sqlite3.Row
            clauses = []
            params: list = []
            if tag:
                clauses.append("tag = ?")
                params.append(tag)
            if since:
                clauses.append("timestamp >= ?")
                params.append(since.isoformat())
            where = ("WHERE " + " AND ".join(clauses)) if clauses else ""
            params.append(limit)
            rows = conn.execute(
                f"SELECT * FROM events {where} ORDER BY timestamp DESC LIMIT ?",
                params
            ).fetchall()
            return [dict(row) for row in rows]

    def get_event_stats(self, since: Optional[datetime] = None) -> dict:
        """Get event statistics, optionally scoped to a time window."""
        with sqlite3.connect(self.db_path) as conn:
            where = ""
            params: list = []
            if since:
                where = "WHERE timestamp >= ?"
                params.append(since.isoformat())
            total = conn.execute(
                f"SELECT COUNT(*) FROM events {where}", params
            ).fetchone()[0]
            tags = conn.execute(
                f"SELECT tag, COUNT(*) as cnt FROM events {where} "
                f"GROUP BY tag ORDER BY cnt DESC",
                params
            ).fetchall()
            return {
                "total": total,
                "by_tag": [{"tag": t[0] or "(untagged)", "count": t[1]} for t in tags]
            }

    def get_tasks_completed_since(self, since: datetime) -> list:
        """Return tasks completed within the given time window."""
        with sqlite3.connect(self.db_path) as conn:
            conn.row_factory = sqlite3.Row
            rows = conn.execute(
                """SELECT * FROM tasks
                   WHERE status = 'completed' AND completed_at >= ?
                   ORDER BY completed_at DESC""",
                (since.isoformat(),)
            ).fetchall()
            return [dict(row) for row in rows]


# =============================================================================
# Helper
# =============================================================================

def _due_indicator(due_at: Optional[str]) -> str:
    """Return a short due-date display string with overdue marker."""
    if not due_at:
        return ""
    try:
        dt = datetime.fromisoformat(due_at)
    except ValueError:
        return due_at[:10]
    now = datetime.now()
    if dt < now:
        return f"🔴{dt.strftime('%m-%d %H:%M')}"
    # Within 24h
    if dt - now < timedelta(hours=24):
        return f"🟡{dt.strftime('%m-%d %H:%M')}"
    return dt.strftime("%Y-%m-%d")


