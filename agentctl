def cmd_add(store: TaskStore, args):
    """Add a new task."""
    tags = args.tags.strip() if args.tags else None
    due_at = None
    if args.due:
        try:
            due_at = parse_due_date(args.due)
        except ValueError as exc:
            print(str(exc), file=sys.stderr)
            sys.exit(1)
    task_id = store.add_task(
        title=args.title,
        description=args.description or "",
        priority=args.priority or "medium",
        metadata=json.loads(args.metadata) if args.metadata else None,
        tags=tags,
        due_at=due_at,
    )
    tag_str = f" [{tags}]" if tags else ""
    due_str = f" due:{due_at[:10]}" if due_at else ""
    print(f"Created task #{task_id}{tag_str}{due_str}: {args.title}")


def cmd_list(store: TaskStore, args):
    """List tasks."""
    tasks = store.list_tasks(
        status=args.status, tag=args.tag, overdue=args.overdue, limit=args.limit
    )

    if not tasks:
        print("No tasks found.")
        return

    print(f"{'ID':>4} {'Status':>12} {'Pri':>5} {'Title':<32} {'Tags':<16} {'Due':<17} {'Created':<10}")
    print("-" * 105)

    for task in tasks:
        status_emoji = {
            "pending": "⏳",
            "in_progress": "🔄",
            "completed": "✅",
            "blocked": "🚫"
        }.get(task["status"], "❓")

        title = task["title"][:30] + ".." if len(task["title"]) > 32 else task["title"]
        tags = (task.get("tags") or "")[:14]
        if task.get("tags") and len(task["tags"]) > 14:
            tags = tags[:12] + ".."
        created = task["created_at"][:10] if task["created_at"] else ""
        due = _due_indicator(task.get("due_at"))[:15]

        print(f"{task['id']:>4} {status_emoji} {task['status']:<10} {task['priority']:<5} {title:<32} {tags:<16} {due:<17} {created:<10}")


def cmd_show(store: TaskStore, args):
    """Show task details."""
    task = store.get_task(args.task_id)
    if not task:
        print(f"Task #{args.task_id} not found.", file=sys.stderr)
        sys.exit(1)

    print(f"Task #{task['id']}: {task['title']}")
    print(f"Status:   {task['status']}")
    print(f"Priority: {task['priority']}")
    if task.get("tags"):
        print(f"Tags:     {task['tags']}")
    if task.get("due_at"):
        indicator = _due_indicator(task["due_at"])
        print(f"Due:      {task['due_at'][:19]}  {indicator}")
    print(f"Created:  {task['created_at']}")
    print(f"Updated:  {task['updated_at']}")
    if task["completed_at"]:
        print(f"Completed:{task['completed_at']}")
    if task["description"]:
        print(f"\nDescription:\n{task['description']}")
    if task["metadata"]:
        print(f"\nMetadata:\n{json.dumps(json.loads(task['metadata']), indent=2)}")

    notes = store.get_notes(args.task_id)
    if notes:
        print(f"\nNotes ({len(notes)}):")
        for n in notes:
            ts = n["timestamp"][:19] if n["timestamp"] else "?"
            print(f"  [{ts}] {n['note']}")


def cmd_update(store: TaskStore, args):
    """Update a task."""
    updates = {}
    if args.title:
        updates["title"] = args.title
    if args.description:
        updates["description"] = args.description
    if args.status:
        updates["status"] = args.status
    if args.priority:
        updates["priority"] = args.priority
    if args.tags is not None:
        updates["tags"] = args.tags
    if args.metadata:
        updates["metadata"] = json.loads(args.metadata)
    if args.due:
        try:
            updates["due_at"] = parse_due_date(args.due)
        except ValueError as exc:
            print(str(exc), file=sys.stderr)
            sys.exit(1)
    if args.clear_due:
        updates["due_at"] = None

    if store.update_task(args.task_id, **updates):
        print(f"Updated task #{args.task_id}")
    else:
        print(f"Task #{args.task_id} not found or no changes.", file=sys.stderr)
        sys.exit(1)


def cmd_note(store: TaskStore, args):
    """Append a timestamped note to a task."""
    task = store.get_task(args.task_id)
    if not task:
        print(f"Task #{args.task_id} not found.", file=sys.stderr)
        sys.exit(1)
    note_id = store.add_note(args.task_id, args.text)
    print(f"Added note #{note_id} to task #{args.task_id}: {args.text[:60]}")


def cmd_delete(store: TaskStore, args):
    """Delete a task."""
    if store.delete_task(args.task_id):
        print(f"Deleted task #{args.task_id}")
    else:
        print(f"Task #{args.task_id} not found.", file=sys.stderr)
        sys.exit(1)


def cmd_status(store: TaskStore, args):
    """Show overall status."""
    stats = store.get_stats()
    print("Task Statistics:")
    print(f"  Total:         {stats['total']}")
    print(f"  ⏳ Pending:     {stats['pending']}")
    print(f"  🔄 In Progress: {stats['in_progress']}")
    print(f"  ✅ Completed:   {stats['completed']}")
    if stats["overdue"]:
        print(f"  🔴 Overdue:     {stats['overdue']}")


def cmd_tags(store: TaskStore, args):
    """List all tags with task counts."""
    tags = store.get_tags()
    if not tags:
        print("No tags found.")
        return
    tag_strs = [f"{tag} ({count})" for tag, count in tags]
    print(" | ".join(tag_strs))


def cmd_state_set(store: TaskStore, args):
    """Set a state value."""
    store.set_state(args.key, args.value)
    print(f"Set {args.key} = {args.value}")


def cmd_state_get(store: TaskStore, args):
    """Get a state value."""
    value = store.get_state(args.key)
    if value is not None:
        print(value)
    else:
        print(f"Key '{args.key}' not set.", file=sys.stderr)
        sys.exit(1)


def cmd_log(store: TaskStore, args):
    """Log a structured event."""
    data = None
    if args.data:
        try:
            data = json.loads(args.data)
        except json.JSONDecodeError as exc:
            print(f"Invalid JSON for --data: {exc}", file=sys.stderr)
            sys.exit(1)

    event_id = store.add_event(message=args.message, tag=args.tag, data=data)
    tag_str = f" [{args.tag}]" if args.tag else ""
    print(f"Logged event #{event_id}{tag_str}: {args.message}")


def cmd_logs(store: TaskStore, args):
    """List recent events."""
    since = None
    if args.since:
        try:
            since = parse_duration(args.since)
        except ValueError as exc:
            print(str(exc), file=sys.stderr)
            sys.exit(1)

    events = store.list_events(tag=args.tag, since=since, limit=args.limit)

    if not events:
        print("No events found.")
        return

    print(f"{'ID':>5} {'Timestamp':<19} {'Tag':<15} {'Message'}")
    print("-" * 80)
    for ev in events:
        tag = (ev["tag"] or "")[:13]
        ts = (ev["timestamp"] or "")[:19]
        msg = ev["message"]
        if len(msg) > 50:
            msg = msg[:48] + ".."
        print(f"{ev['id']:>5} {ts:<19} {tag:<15} {msg}")
        if ev["data"] and args.data:
            print(f"       data: {ev['data']}")


def cmd_report(store: TaskStore, args):
    """Generate a summary report of tasks and events."""
    since_str = args.since or "24h"
    try:
        since = parse_duration(since_str)
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        sys.exit(1)

    window_label = since_str
    now_label = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    since_label = since.strftime("%Y-%m-%d %H:%M:%S")

    print("=" * 60)
    print(f"  agentctl Report  |  last {window_label}")
    print(f"  Generated: {now_label}")
    print(f"  Window start: {since_label}")
    print("=" * 60)

    stats = store.get_stats()
    print("\n-- Tasks (all time) --")
    print(f"  Total:         {stats['total']}")
    print(f"  ⏳ Pending:     {stats['pending']}")
    print(f"  🔄 In Progress: {stats['in_progress']}")
    print(f"  ✅ Completed:   {stats['completed']}")
    if stats["overdue"]:
        print(f"  🔴 Overdue:     {stats['overdue']}")

    completed_recent = store.get_tasks_completed_since(since)
    if completed_recent:
        print(f"\n-- Tasks completed in last {window_label} --")
        for task in completed_recent:
            ts = (task["completed_at"] or "")[:19]
            print(f"  #{task['id']:>3} [{ts}] {task['title']}")
    else:
        print(f"\n  No tasks completed in the last {window_label}.")

    overdue_tasks = store.list_tasks(overdue=True, limit=10)
    if overdue_tasks:
        print("\n-- Overdue tasks --")
        for task in overdue_tasks:
            due = (task.get("due_at") or "")[:19]
            print(f"  #{task['id']:>3} [{due}] {task['title']} ({task['status']})")

    ev_stats = store.get_event_stats(since=since)
    print(f"\n-- Events in last {window_label} --")
    print(f"  Total events: {ev_stats['total']}")
    if ev_stats["by_tag"]:
        print("  By tag:")
        for entry in ev_stats["by_tag"]:
            print(f"    {entry['tag']:<20} {entry['count']}")

    recent_events = store.list_events(since=since, limit=10)
    if recent_events:
        print(f"\n-- Recent events (up to 10) --")
        for ev in recent_events:
            ts = (ev["timestamp"] or "")[:19]
            tag = f"[{ev['tag']}] " if ev["tag"] else ""
            print(f"  #{ev['id']:>3} [{ts}] {tag}{ev['message']}")

    print("\n" + "=" * 60)


def cmd_checkpoint(store: TaskStore, args):
    """Export full state to a JSON checkpoint file."""
    data = store.export_all()
    out_path = Path(args.output) if args.output else Path(
        f"agentctl-checkpoint-{datetime.now().strftime('%Y%m%d-%H%M%S')}.json"
    )
    out_path.write_text(json.dumps(data, indent=2))
    counts = (
        f"{len(data['tasks'])} tasks, {len(data['state'])} state keys, "
        f"{len(data['events'])} events, {len(data['notes'])} notes"
    )
    print(f"Checkpoint saved: {out_path} ({counts})")


def cmd_restore(store: TaskStore, args):
    """Restore state from a checkpoint file."""
    in_path = Path(args.file)
    if not in_path.exists():
        print(f"File not found: {in_path}", file=sys.stderr)
        sys.exit(1)
    data = json.loads(in_path.read_text())
    store.import_all(data, merge=args.merge)
    mode = "merged into" if args.merge else "restored to"
    counts = (
        f"{len(data.get('tasks', []))} tasks, {len(data.get('state', []))} state keys, "
        f"{len(data.get('events', []))} events, {len(data.get('notes', []))} notes"
    )
    print(f"Data {mode} database ({counts})")


def cmd_purge(store: TaskStore, args):
    """Purge data from the database."""
    target = args.target or "all"
    if not args.yes:
        answer = input(f"Purge {target}? This cannot be undone. [y/N] ")
        if answer.lower() != "y":
            print("Aborted.")
            return
    store.purge(target)
    print(f"Purged: {target}")


